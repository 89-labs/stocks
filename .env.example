# MongoDB (Atlas free tier works)
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="naijastocks"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic link (optional)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@naijastocks.com"

# Upstash Redis (optional, recommended for production caching + rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# NGX live board prices (primary quote source) — https://ngxpulse.ng/api
NGX_PULSE_API_KEY=""
# Refresh gate: max ~72 calls/day at 20 min; hard cap 80/day
# NGX_PULSE_REFRESH_MINUTES=20
# NGX_PULSE_DAILY_MAX_REQUESTS=80

# iTick API — get your token at https://itick.org/dashboard
ITICK_API_KEY=
# Free tier (default): https://api-free.itick.org — paid: https://api.itick.org
ITICK_BASE_URL=https://api-free.itick.org
# Optional: free-tier rate limit tuning
# ITICK_LIVE_QUOTES_LIMIT=30
# ITICK_QUOTES_BATCH_SIZE=5
# ITICK_QUOTES_BATCH_DELAY_MS=600

# Optional: NGN/USD via ExchangeRate-API
EXCHANGE_RATE_API_KEY=""

# Anthropic Claude (optional — AI features degrade gracefully without it)
ANTHROPIC_API_KEY=""

# Vercel Cron — secures GET /api/news/refresh (news re-ingest every 3 hours)
CRON_SECRET="generate-with: openssl rand -base64 32"
